# Accept string
s = input("Enter a string: ")

vowels = consonants = special = 0

for ch in s:
    if ch.isalpha():
        if ch.lower() in "aeiou":
            vowels += 1
        else:
            consonants += 1
    else:
        special += 1

print("Vowels:", vowels)
print("Consonants:", consonants)
print("Special symbols:", special)



filename = input("Enter file name: ")
position = int(input("Enter byte position: "))

try:
    with open(filename, "r") as f:
        f.seek(position)   # Move pointer

        content = f.read()  # Read from position
        print("Content from position:\n", content)

except FileNotFoundError:
    print("Error: File does not exist!")
