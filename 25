import random

suits = ['Hearts', 'Diamonds', 'Clubs', 'Spades']
ranks = ['2', '3', '4', '5', '6', '7', '8', '9', '10', 'Jack', 'Queen', 'King', 'Ace']

deck = [(r, s) for s in suits for r in ranks]

random.shuffle(deck)

print("5 Cards drawn:")
for i in range(5):
    print(deck[i])


