import random

r = random.randint(1, 10)
circumference = 2 * 3.14 * r

print("Radius:", r)
print("Circumference:", circumference)


import re

pwd = input("Enter password: ")

pattern = r'^(?=.*[a-z])(?=.*\d)(?=.*[$#@])[A-Za-z\d$#@]{6,12}$'

print("Valid Password" if re.match(pattern, pwd) else "Invalid Password")
