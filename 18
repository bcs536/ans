    import re

mobile = input("Enter mobile number: ")

# Pattern:
# (0 or 91 optional) + first digit 6-9 + remaining 9 digits
pattern = r'^(0|91)?[6-9][0-9]{9}$'

if re.match(pattern, mobile):
    print("Valid Mobile Number")
else:
    print("Invalid Mobile Number")
